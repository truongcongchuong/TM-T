{
  "version": "0.2.0",
  "compounds": [
    {
      "name": "Debug Fullstack",
      "configurations": [
        "backend",
        "frontend"
      ]
    }
  ],
  "configurations": [
    {
      "name": "backend",
      "type": "dart",
      "request": "launch",
      "program": "${workspaceFolder}/backend/bin/backend.dart",
      "cwd": "${workspaceFolder}/backend"
    },
    {
      "name": "frontend",
      "type": "dart",
      "request": "launch",
      "program": "${workspaceFolder}/frontend/lib/main.dart",
      "cwd": "${workspaceFolder}/frontend",
      "flutterMode": "debug",
    }
  ]
}
